@page "/dashboard"
@using RachaAi.Models

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Olá, Mateus 👋</h2>
        <button class="btn btn-primary rounded-pill px-4 shadow-sm">Novo Gasto</button>
    </div>

    <div class="row mb-5 text-center">
        <div class="col-md-4 mb-3">
            <div class="card bg-primary text-white shadow-sm border-0 p-3" style="border-radius: 15px;">
                <small class="opacity-75">Saldo Geral</small>
                <h3 class="fw-bold">R$ 798,60</h3>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm border-0 p-3" style="border-radius: 15px;">
                <small class="text-success fw-bold">A Receber</small>
                <h3 class="text-success fw-bold">R$ 1.285,00</h3>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm border-0 p-3" style="border-radius: 15px;">
                <small class="text-danger fw-bold">A Pagar</small>
                <h3 class="text-danger fw-bold">R$ 486,40</h3>
            </div>
        </div>
    </div>

    <h6 class="text-muted fw-bold mb-3">SEUS GRUPOS ATIVOS</h6>
    
    @foreach (var grupo in meusGrupos)
    {
        <GrupoCard Grupo="grupo" />
    }
</div>

@code {
    private List<Grupo> meusGrupos = new()
    {
        new Grupo { Nome = "República Central", Categoria = "Casa", ValorPendente = 450.50m, NoVermelho = true },
        new Grupo { Nome = "Churrasco de Domingo", Categoria = "Lazer", ValorPendente = 85.00m, NoVermelho = false },
        new Grupo { Nome = "Viagem Floripa", Categoria = "Viagem", ValorPendente = 1200.00m, NoVermelho = false },
        new Grupo { Nome = "Netflix & Internet", Categoria = "Contas", ValorPendente = 35.90m, NoVermelho = true }
    };
}