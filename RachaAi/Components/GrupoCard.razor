@using RachaAi.Models

<div class="card mb-3 shadow-sm border-0" style="border-radius: 12px;">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <span class="badge bg-light text-secondary mb-1">@Grupo.Categoria</span>
            <h5 class="fw-bold mb-0">@Grupo.Nome</h5>
        </div>
        <div class="text-end">
            <small class="@(Grupo.NoVermelho ? "text-danger" : "text-success") fw-bold">
                @(Grupo.NoVermelho ? "Você deve" : "Você recebe")
            </small>
            <p class="fs-5 fw-bold @(Grupo.NoVermelho ? "text-danger" : "text-success") mb-0">
                R$ @Grupo.ValorPendente.ToString("N2")
            </p>
        </div>
    </div>
</div>

@code {
    [Parameter] public Grupo Grupo { get; set; } = new();
}